  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Digital Twin Medicine — HF TRL (Colab)\\n",
        "\\n",
        "**Goal:** minimal training script using **HuggingFace TRL** that actually interacts with the environment and learns.\\n",
        "\\n",
        "This notebook trains a small model (`distilgpt2`) with **PPO** to output JSON treatment actions.\\n",
        "\\n",
        "It uses the core environment directly (fast + no Docker). For submission, you will also deploy the OpenEnv server to Hugging Face Spaces (steps at end).\\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": [
        "# If you cloned the repo in Colab, install deps from the local file:\n",
        "# !pip -q install -r requirements_hackathon.txt\n",
        "# Otherwise, install from GitHub raw (replace placeholders):\n",
        "# !pip -q install -r https://raw.githubusercontent.com/<YOUR_GITHUB>/<YOUR_REPO>/main/requirements_hackathon.txt\n",
        "\n",
        "# Fallback (minimal):\n",
        "!pip -q install trl transformers accelerate datasets wandb openenv\n",
        "\n",
        "# Colab usually already has torch. If not:\n",
        "# !pip -q install torch\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": [
        "# If you are running from a GitHub repo, clone it and set path:\n",
        "# !git clone https://github.com/<YOUR_GITHUB>/<YOUR_REPO>.git\n",
        "# %cd <YOUR_REPO>\n",
        "\n",
        "import os, sys\n",
        "from pathlib import Path\n",
        "\n",
        "repo_root = Path.cwd()\n",
        "sys.path.insert(0, str(repo_root))\n",
        "print('repo_root:', repo_root)\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": [
        "import json\n",
        "import numpy as np\n",
        "import torch\n",
        "\n",
        "from env.digital_twin_env import DigitalTwinDiabetesEnv\n",
        "from env.action_parser import safe_action\n",
        "\n",
        "device = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
        "print('device:', device)\n",
        "\n",
        "def make_env(seed: int):\n",
        "    return DigitalTwinDiabetesEnv(seed=seed, max_steps=24)\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": [
        "from transformers import AutoTokenizer\n",
        "from trl import AutoModelForCausalLMWithValueHead, PPOConfig, PPOTrainer\n",
        "\n",
        "model_name = 'distilgpt2'\n",
        "tokenizer = AutoTokenizer.from_pretrained(model_name)\n",
        "tokenizer.pad_token = tokenizer.eos_token\n",
        "\n",
        "model = AutoModelForCausalLMWithValueHead.from_pretrained(model_name).to(device)\n",
        "\n",
        "ppo_config = PPOConfig(\n",
        "    batch_size=8,\n",
        "    mini_batch_size=4,\n",
        "    learning_rate=1e-5,\n",
        "    log_with=None,\n",
        ")\n",
        "\n",
        "ppo_trainer = PPOTrainer(\n",
        "    config=ppo_config,\n",
        "    model=model,\n",
        "    tokenizer=tokenizer,\n",
        ")\n",
        "\n",
        "print('PPO ready')\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": [
        "def obs_to_prompt(obs: dict) -> str:\n",
        "    # Keep it compact and consistent to learn JSON formatting.\n",
        "    return (\n",
        "        'You are a treatment policy. Output ONE JSON action only.\\n'\n",
        "        f\"week: {obs['week']}\\n\"\n",
        "        f\"hba1c: {obs['hba1c']:.2f}\\n\"\n",
        "        f\"fasting_glucose: {obs['fasting_glucose']:.0f}\\n\"\n",
        "        f\"bmi: {obs['bmi']:.1f}\\n\"\n",
        "        f\"egfr: {obs['egfr']:.0f}\\n\"\n",
        "        f\"ckd: {obs['ckd']} cvd: {obs['cvd']}\\n\"\n",
        "        'Allowed drugs: metformin, glp1, sglt2, dpp4, sulfonylurea, insulin.\\n'\n",
        "        'Action schema examples:\\n'\n",
        "        '{\"type\":\"start\",\"drug\":\"metformin\",\"dose\":1.0,\"lifestyle\":0.7}\\n'\n",
        "        '{\"type\":\"add\",\"drug\":\"glp1\",\"dose\":1.0}\\n'\n"
        "        'Now output JSON:'\n",
        "    )\n",
        "\n",
        "\n",
        "def generate_action_text(prompt: str, max_new_tokens: int = 80) -> str:\n",
        "    x = tokenizer(prompt, return_tensors='pt', padding=True).to(device)\n",
        "    with torch.no_grad():\n",
        "        y = model.generate(\n",
        "            **x,\n",
        "            max_new_tokens=max_new_tokens,\n",
        "            do_sample=True,\n",
        "            temperature=0.9,\n",
        "            top_p=0.95,\n",
        "        )\n",
        "    txt = tokenizer.decode(y[0], skip_special_tokens=True)\n",
        "    # Return only the suffix after prompt to reduce junk\n",
        "    return txt[len(prompt):].strip()\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": [
        "def rollout_episode(seed: int, max_steps: int = 24):\n",
        "    env = make_env(seed)\n",
        "    obs, _ = env.reset(seed=seed)\n",
        "    traj = []\n",
        "    for t in range(max_steps):\n",
        "        prompt = obs_to_prompt(obs)\n",
        "        action_text = generate_action_text(prompt)\n",
        "        action_dict, parse_info = safe_action(action_text)\n",
        "        next_obs, r, term, trunc, info = env.step(action_dict)\n",
        "        traj.append({\n",
        "            'prompt': prompt,\n",
        "            'action_text': action_text,\n",
        "            'action': action_dict,\n",
        "            'parse_ok': parse_info['ok'],\n",
        "            'reward': float(r),\n",
        "            'obs': obs,\n",
        "        })\n",
        "        obs = next_obs\n",
        "        if term or trunc:\n",
        "            break\n",
        "    return traj\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": [
        "def ppo_step(batch_traj):\n",
        "    # PPOTrainer expects query tensors + response tensors + rewards\n",
        "    queries = [x['prompt'] for x in batch_traj]\n",
        "    responses = [x['action_text'] for x in batch_traj]\n",
        "    rewards = [x['reward'] for x in batch_traj]\n",
        "\n",
        "    q_t = [tokenizer(q, return_tensors='pt').input_ids.squeeze(0) for q in queries]\n",
        "    r_t = [tokenizer(r, return_tensors='pt').input_ids.squeeze(0) for r in responses]\n",
        "    rew_t = [torch.tensor(r, dtype=torch.float32) for r in rewards]\n",
        "\n",
        "    stats = ppo_trainer.step(q_t, r_t, rew_t)\n",
        "    return stats\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": [
        "returns = []\n",
        "parse_ok_rate = []\n",
        "\n",
        "for it in range(40):\n",
        "    # collect rollouts\n",
        "    batch = []\n",
        "    batch_returns = []\n",
        "    ok = []\n",
        "    for ep in range(ppo_config.batch_size):\n",
        "        traj = rollout_episode(seed=it * 100 + ep)\n",
        "        G = sum(x['reward'] for x in traj)\n",
        "        batch_returns.append(G)\n",
        "        ok.extend([1.0 if x['parse_ok'] else 0.0 for x in traj])\n",
        "        # credit assignment simplification: train on last step only\n",
        "        batch.append(traj[-1])\n",
        "\n",
        "    stats = ppo_step(batch)\n",
        "    returns.append(float(np.mean(batch_returns)))\n",
        "    parse_ok_rate.append(float(np.mean(ok)) if ok else 0.0)\n",
        "\n",
        "    if (it + 1) % 5 == 0:\n",
        "        print(f\"it={it+1:03d} avg_return={returns[-1]:+.2f} parse_ok={parse_ok_rate[-1]:.2f}\")\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": [
        "import matplotlib.pyplot as plt\n",
        "\n",
        "plt.figure(figsize=(8,3))\n",
        "plt.plot(returns)\n",
        "plt.title('TRL PPO training: average return')\n",
        "plt.xlabel('iteration')\n",
        "plt.ylabel('avg return')\n",
        "plt.grid(True)\n",
        "plt.show()\n",
        "\n",
        "plt.figure(figsize=(8,3))\n",
        "plt.plot(parse_ok_rate)\n",
        "plt.title('Action JSON parse success rate')\n",
        "plt.xlabel('iteration')\n",
        "plt.ylabel('rate')\n",
        "plt.grid(True)\n",
        "plt.show()\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
