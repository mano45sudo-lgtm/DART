},
{
"cell_type": "code",
"source": [
"import os, sys\n",
"from pathlib import Path\n",
"repo_root = Path.cwd()\n",
"sys.path.insert(0, str(repo_root))"
]
},
{
"cell_type": "code",
"source": [
"import numpy as np\n",
"import torch\n",
"from env.digital_twin_env import DigitalTwinDiabetesEnv\n",
"from env.action_parser import safe_action\n",
"device = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
"def make_env(seed): return DigitalTwinDiabetesEnv(seed=seed, max_steps=24)"
]
},
{
"cell_type": "code",
"source": [
"from transformers import AutoTokenizer\n",
"from trl import AutoModelForCausalLMWithValueHead, PPOConfig, PPOTrainer\n",
"model_name='distilgpt2'\n",
"tokenizer=AutoTokenizer.from_pretrained(model_name)\n",
"tokenizer.pad_token=tokenizer.eos_token\n",
"model=AutoModelForCausalLMWithValueHead.from_pretrained(model_name).to(device)\n",
"ppo_config=PPOConfig(batch_size=8,mini_batch_size=4,learning_rate=1e-5)\n",
"ppo_trainer=PPOTrainer(config=ppo_config,model=model,tokenizer=tokenizer)"
]
},
{
"cell_type": "code",
"source": [
"def obs_to_prompt(obs):\n",
"    return (\n",
"        "You are a treatment policy. Output ONE JSON action only.\n"\n",
"        f"week: {obs['week']}\n"\n",
"        f"hba1c: {obs['hba1c']:.2f}\n"\n",
"        f"fasting_glucose: {obs['fasting_glucose']:.0f}\n"\n",
"        f"bmi: {obs['bmi']:.1f}\n"\n",
"        f"egfr: {obs['egfr']:.0f}\n"\n",
"        f"ckd: {obs['ckd']} cvd: {obs['cvd']}\n"\n",
"        "Allowed drugs: metformin, glp1, sglt2, dpp4, sulfonylurea, insulin.\n"\n",
"        "Action schema examples:\n"\n",
"        '{"type":"start","drug":"metformin","dose":1.0,"lifestyle":0.7}\n'\n",
"        '{"type":"add","drug":"glp1","dose":1.0}\n'\n",
"        "Now output JSON:"\n",
"    )"
]
},
{
"cell_type": "code",
"source": [
"def generate_action(prompt):\n",
"    x=tokenizer(prompt,return_tensors='pt').to(device)\n",
"    y=model.generate(**x,max_new_tokens=80,do_sample=True,temperature=0.9,top_p=0.95)\n",
"    txt=tokenizer.decode(y[0],skip_special_tokens=True)\n",
"    return txt[len(prompt):].strip()"
]
},
{
"cell_type": "code",
"source": [
"def rollout(seed):\n",
"    env=make_env(seed)\n",
"    obs,*=env.reset(seed=seed)\n",
"    traj=[]\n",
"    for _ in range(24):\n",
"        p=obs_to_prompt(obs)\n",
"        a_txt=generate_action(p)\n",
"        a_dict,info=safe_action(a_txt)\n",
"        obs,r,done,*,_=env.step(a_dict)\n",
"        traj.append({'prompt':p,'resp':a_txt,'reward':r,'ok':info})\n",
"        if done: break\n",
"    return traj"
]
},
{
"cell_type": "code",
"source": [
"# BASELINE\n",
"baseline=[]\n",
"for i in range(20):\n",
"    traj=rollout(1000+i)\n",
"    baseline.append(sum(x['reward'] for x in traj))\n",
"print('baseline avg:',np.mean(baseline))"
]
},
{
"cell_type": "code",
"source": [
"# TRAINING\n",
"returns=[];parse_ok=[]\n",
"for it in range(30):\n",
"    batch=[];rets=[];oks=[]\n",
"    for ep in range(ppo_config.batch_size):\n",
"        traj=rollout(it*100+ep)\n",
"        rets.append(sum(x['reward'] for x in traj))\n",
"        oks.extend([1 if x['ok'] else 0 for x in traj])\n",
"        batch.append(traj[-1])\n",
"    q=[x['prompt'] for x in batch]\n",
"    r=[x['resp'] for x in batch]\n",
"    rew=[torch.tensor(x['reward']) for x in batch]\n",
"    qt=[tokenizer(x,return_tensors='pt').input_ids.squeeze(0) for x in q]\n",
"    rt=[tokenizer(x,return_tensors='pt').input_ids.squeeze(0) for x in r]\n",
"    ppo_trainer.step(qt,rt,rew)\n",
"    returns.append(np.mean(rets))\n",
"    parse_ok.append(np.mean(oks))\n",
"    print(it,returns[-1])"
]
},
{
"cell_type": "code",
"source": [
"# TRAINED EVAL\n",
"trained=[]\n",
"for i in range(20):\n",
"    traj=rollout(2000+i)\n",
"    trained.append(sum(x['reward'] for x in traj))\n",
"print('trained avg:',np.mean(trained))"
]
},
{
"cell_type": "code",
"source": [
"import matplotlib.pyplot as plt\n",
"os.makedirs('logs',exist_ok=True)\n",
"plt.figure()\n",
"plt.plot(returns,label='training')\n",
"plt.axhline(np.mean(baseline),linestyle='--',label='baseline')\n",
"plt.xlabel('Training Iteration')\n",
"plt.ylabel('Reward')\n",
"plt.title('RL Training vs Baseline')\n",
"plt.legend();plt.grid()\n",
"plt.savefig('logs/comparison.png')\n",
"plt.show()"
]
}
],
